<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    FIX: Xóa fallback package folder trỏ về Windows path
    C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
    
    Khi build Docker trên Linux, NuGet tìm đường dẫn Windows này → lỗi
    "Unable to find fallback package folder"
    
    <clear /> xóa toàn bộ fallback folders, chỉ dùng global packages cache
    trong container (/root/.nuget/packages)
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
